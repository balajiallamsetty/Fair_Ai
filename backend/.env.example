# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/fair_ai_db

# Security
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Environment
ENVIRONMENT=development

# CORS Configuration
# Options:
#   - "vercel" : Allow all Vercel preview & production deployments (*.vercel.app)
#   - Comma-separated list: https://domain1.com,https://domain2.com
#   - Include http://localhost:3000 for local development
CORS_ORIGINS=vercel

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
