# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/fair_ai_db

# Security
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Environment
ENVIRONMENT=development

# CORS Configuration
# For production: https://fair-ai-git-main-balajiallamsettys-projects.vercel.app,https://fair-ai-sable.vercel.app
# For development: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,https://fair-ai-git-main-balajiallamsettys-projects.vercel.app,https://fair-ai-sable.vercel.app

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
